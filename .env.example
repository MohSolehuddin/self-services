# Docker Compose dengan .env template

# --- GENERAL ---
PUID=1000
PGID=1000

# --- DATABASE UTAMA (Gitea/Nextcloud) ---
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_PASSWORD_123!

# --- CLOUDFLARE TUNNEL ---
CLOUDFLARE_TUNNEL_TOKEN=YOUR_CLOUDFLARE_TUNNEL_TOKEN_HERE

# --- CODE SERVER ---
CODESERVER_PASSWORD=CHANGE_THIS_CODESERVER_PASSWORD

# --- SOURCEBOT CONFIG ---
SB_DB_USER=sb_admin
SB_DB_PASSWORD=CHANGE_THIS_SB_PASSWORD
REDIS_URL=redis://redis_sb:6379
DATABASE_URL=postgresql://sb_admin:CHANGE_THIS_SB_PASSWORD@postgres_sb:5432/sourcebot

# --- WAHA CONFIG ---
WHATSAPP_API_KEY=CHANGE_THIS_WHATSAPP_API_KEY
